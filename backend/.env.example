# ─── Smart Lecturer Review System — Environment Variables ───────────
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to git.

# Django
DJANGO_SECRET_KEY=your-very-long-random-secret-key-change-this-now-50plus-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# MySQL Database
DB_NAME=smart_lecturer_db
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=localhost
DB_PORT=3306

# College email domain (students/staff must register with this domain)
COLLEGE_EMAIL_DOMAIN=college.edu
